@model DevicesObservabilityViewModel

@{
    ViewData["Title"] = "لوحة نشاط الأجهزة";
    var zeroSuccessCount = Model.Devices.Count(x => x.ActivityCount == 0 && x.FailedAuthCount > 0);
    var distinctAreas = Model.Devices
        .Select(d => d.Area)
        .Where(a => !string.IsNullOrWhiteSpace(a))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(a => a, StringComparer.OrdinalIgnoreCase)
        .ToList();
    var hasUnassignedArea = Model.Devices.Any(d => string.IsNullOrWhiteSpace(d.Area));
}


<div class="content-card fade-in">
    <div class="page-header">
        <h1 class="page-title">
            <span class="page-title-icon">📡</span>
            <span>لوحة نشاط الأجهزة</span>
        </h1>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-error">
            <span>@Model.Error</span>
        </div>
    }

    <div class="obs-summary-grid mb-3">
        <div class="obs-summary-card is-neutral">
            <div class="obs-summary-label">إجمالي الأجهزة</div>
            <div class="obs-summary-value">@Model.TotalDevices</div>
        </div>
        <div class="obs-summary-card is-inactive">
            <div class="obs-summary-label">لا يوجد استخدام</div>
            <div class="obs-summary-value">@Model.NoActivityDevices</div>
        </div>
        <div class="obs-summary-card is-week">
            <div class="obs-summary-label">نشط هذا الأسبوع</div>
            <div class="obs-summary-value">@Model.ActiveThisWeekDevices</div>
        </div>
        <div class="obs-summary-card is-success">
            <div class="obs-summary-label">نشط اليوم</div>
            <div class="obs-summary-value">@Model.ActiveTodayDevices</div>
        </div>
        <div class="obs-summary-card is-alert @(Model.SecurityAlertDevices > 0 ? "has-alerts" : "")">
            <div class="obs-summary-label">تحذيرات أمنية</div>
            <div class="obs-summary-value">@Model.SecurityAlertDevices</div>
            @if (zeroSuccessCount > 0)
            {
                <div class="obs-alert-sub">منها @zeroSuccessCount بلا أي نجاحات</div>
            }
        </div>
    </div>

    <div class="u-flex u-items-center u-justify-between u-gap-12 u-flex-wrap u-mb-12">
        <h2 class="c-section-title">نشاط الأجهزة خلال آخر 7 أيام</h2>

        @if (Model.Devices.Any())
        {
            <div class="u-flex u-items-center u-gap-10">
                <select id="areaFilter" class="form-control form-control-compact obs-filter-select" onchange="filterByArea()">
                    <option value="all" selected>كل المناطق</option>
                    @if (hasUnassignedArea)
                    {
                        <option value="unassigned">بدون منطقة</option>
                    }
                    @foreach (var area in distinctAreas)
                    {
                        <option value="@area">@area</option>
                    }
                </select>
                <span class="text-muted small obs-filter-count" id="areaFilterCount"></span>
                <button type="button" id="areaFilterClear" class="obs-filter-clear" onclick="clearAreaFilter()" hidden>
                    مسح التصفية ×
                </button>
            </div>
        }
    </div>

    <div class="table-container">
        <table class="data-table" id="devicesTable">
            <thead>
                <tr>
                    <th>الجهاز</th>
                    <th class="u-w-140">المنطقة</th>
                    <th class="u-w-160">حالة النشاط</th>
                    <th class="obs-th-sortable u-w-160" id="sortableRateHeader" onclick="sortByRate()"
                        tabindex="0" role="button" aria-label="ترتيب حسب نسبة الفشل" title="اضغط للترتيب">
                        نسبة الفشل
                        <span class="obs-sort-arrow" id="sortArrow">▼</span>
                    </th>
                    <th class="u-w-150">آخر نشاط</th>
                    <th class="u-w-150">آخر فشل</th>
                </tr>
            </thead>
            <tbody id="devicesTableBody">
            @if (!Model.Devices.Any())
            {
                <tr>
                    <td colspan="6" class="u-text-center text-muted">لا توجد بيانات أجهزة متاحة حالياً.</td>
                </tr>
            }
            else
            {
                @foreach (var device in Model.Devices)
                {
                    var total = device.ActivityCount + device.FailedAuthCount;
                    var failureRate = total > 0 ? (device.FailedAuthCount * 100 / total) : 0;
                    var isZeroSuccess = device.ActivityCount == 0 && device.FailedAuthCount > 0;

                    var rowClass = failureRate >= 80 ? "obs-row-danger"
                                 : failureRate >= 30 ? "obs-row-warning"
                                 : "";

                    var ratePillClass = failureRate >= 80 ? "is-danger"
                                      : failureRate >= 30 ? "is-warning"
                                      : "is-ok";

                    <tr class="@rowClass" data-rate="@failureRate" data-area="@(string.IsNullOrWhiteSpace(device.Area) ? "unassigned" : device.Area)">
                        <td>
                            <div class="obs-device-name">@device.Name</div>
                            @if (!string.IsNullOrWhiteSpace(device.TerminalId))
                            {
                                <div class="obs-device-meta">@device.TerminalId</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(device.Area))
                            {
                                <span class="obs-area-text">@device.Area</span>
                            }
                            else
                            {
                                <span class="obs-area-text is-muted">بدون منطقة</span>
                            }
                        </td>
                        <td>
                            @if (device.Status == "Active Today")
                            {
                                <span class="badge badge-success">نشط اليوم</span>
                            }
                            else if (device.Status == "Active This Week")
                            {
                                <span class="badge badge-week">نشط هذا الأسبوع</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">لا يوجد استخدام</span>
                            }
                            @if (isZeroSuccess)
                            {
                                <div><span class="badge-zero-success">⚠️ لا توجد نجاحات</span></div>
                            }
                        </td>
                        <td>
                            @if (total > 0)
                            {
                                <div><span class="obs-rate-pill @ratePillClass">@failureRate٪ فشل</span></div>
                                <div class="obs-count-minor">✓ @device.ActivityCount / ✗ @device.FailedAuthCount</div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted small">
                            @(device.LastSeen.HasValue ? device.LastSeen.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                        </td>
                        <td>
                            @if (device.LastFailedAt.HasValue)
                            {
                                <span class="@(failureRate >= 30 ? "text-danger fw-bold" : "text-muted") small">
                                    @device.LastFailedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
                <tr id="areaNoMatchRow" hidden>
                    <td colspan="6">
                        <div class="obs-no-match">
                            <span class="obs-no-match-icon">🔍</span>
                            <span>لا توجد أجهزة في هذه المنطقة</span>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    var _sortDesc = true;

    function sortByRate() {
        var tbody = document.getElementById('devicesTableBody');
        var rows = Array.from(tbody.querySelectorAll('tr[data-rate]'));
        _sortDesc = !_sortDesc;
        rows.sort(function (a, b) {
            var av = parseInt(a.dataset.rate, 10) || 0;
            var bv = parseInt(b.dataset.rate, 10) || 0;
            return _sortDesc ? bv - av : av - bv;
        });
        rows.forEach(function (r) { tbody.appendChild(r); });
        var arrow = document.getElementById('sortArrow');
        if (arrow) arrow.classList.toggle('is-asc', !_sortDesc);
    }

    (function () {
        var header = document.getElementById('sortableRateHeader');
        if (!header) return;
        header.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                sortByRate();
            }
        });
    })();

    function filterByArea() {
        var select = document.getElementById('areaFilter');
        if (!select) return;

        var tbody = document.getElementById('devicesTableBody');
        var rows = Array.from(tbody.querySelectorAll('tr[data-rate]'));
        var noMatchRow = document.getElementById('areaNoMatchRow');
        var countLabel = document.getElementById('areaFilterCount');
        var clearBtn = document.getElementById('areaFilterClear');
        var value = select.value;
        var visibleCount = 0;

        rows.forEach(function (row) {
            var matches = value === 'all' || row.getAttribute('data-area') === value;
            row.classList.toggle('is-hidden-by-filter', !matches);
            if (matches) visibleCount++;
        });

        if (noMatchRow) noMatchRow.hidden = rows.length === 0 || visibleCount !== 0;
        if (clearBtn) clearBtn.hidden = value === 'all';

        if (countLabel) {
            countLabel.textContent = value === 'all'
                ? ''
                : 'عرض ' + visibleCount + ' من ' + rows.length + ' جهاز';
        }
    }

    function clearAreaFilter() {
        var select = document.getElementById('areaFilter');
        if (!select) return;
        select.value = 'all';
        filterByArea();
    }
</script>
}

@model FingerprintManagementSystem.Contracts.DTOs.EmployeeDevicesScreenDto
@{
ViewData["Title"] = "بحث موظف";
var toastType = TempData["ToastType"] as string;
var toastMsg = TempData["ToastMsg"] as string;
var lastEmployeeId = TempData["LastEmployeeId"]?.ToString();
var devices = Model?.Devices ?? new List<FingerprintManagementSystem.Contracts.DTOs.DeviceRowDto>();
var assigned = devices.Where(x => x.IsEffectivelyAssigned).ToList();
var unassigned = devices.Where(x => !x.IsEffectivelyAssigned).ToList();
}
@{
var selectedTerminalsRaw = TempData["SelectedTerminalIds"] as string;
var selectedTerminals = new HashSet<string>(
(selectedTerminalsRaw ?? "")
.Split(',', StringSplitOptions.RemoveEmptyEntries)
.Select(x => x.Trim()),
StringComparer.OrdinalIgnoreCase
);
}

@section Styles {
    <!-- Font Awesome for professional icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Flatpickr for date formatting -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <!-- أنماط خاصة بصفحة البحث فقط -->
}

<div class="employees-search-page">
<!-- جزيئات الخلفية من site.css -->
<div class="bg-particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
</div>


<!-- المحتوى الرئيسي - باقي الكود كما هو -->
<div class="main-content">
    @{
    var isAdmin = Context.Session.GetString("IsAdmin") == "1";
    }

    <div class="page-header">
        <h1><i class="fa-solid fa-magnifying-glass icon"></i> بحث عن موظف</h1>
        @if (isAdmin)
        {
            <button id="autoAssignBtn" class="btn-admin-action">
                <i class="fa-solid fa-rotate"></i>
                <span>تحديث توزيع الأجهزة</span>
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(toastMsg))
    {
        var alertClass = "alert-info";
        var alertIcon = "fa-circle-info";
        var alertTitle = "معلومة";

        if (toastType == "success")
        {
            alertClass = "alert-success";
            alertIcon = "fa-circle-check";
            alertTitle = "نجح";
        }
        else if (toastType == "danger")
        {
            alertClass = "alert-danger";
            alertIcon = "fa-circle-xmark";
            alertTitle = "خطأ";
        }
        else if (toastType == "warning")
        {
            alertClass = "alert-warning";
            alertIcon = "fa-triangle-exclamation";
            alertTitle = "تحذير";
        }

        <div class="alert @alertClass">
            <div class="alert-icon"><i class="fa-solid @alertIcon"></i></div>
            <div class="alert-content">
                <div class="alert-title">@alertTitle</div>
                <div class="alert-message">@toastMsg</div>
            </div>
        </div>
    }

    <div class="premium-card">
        <div class="section-header">
            <div class="section-number">1</div>
            <h3 class="section-title">البحث عن الموظف</h3>
        </div>

        <form method="post" action="/employees/search">
            @Html.AntiForgeryToken()
            <div class="form-field">
                <label class="form-label">
                    <i class="fa-solid fa-id-card icon"></i>
                    الرقم الوظيفي للموظف
                </label>
                <input type="number" name="employeeId" class="form-input"
                       placeholder="أدخل الرقم الوظيفي للبحث..."
                       value="@(Model?.Employee?.EmployeeId.ToString() ?? lastEmployeeId ?? "")"
                       required/>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-magnifying-glass icon"></i>
                    <span>بحث</span>
                </button>
            </div>
        </form>
    </div>

    @if (Model?.Employee != null)
    {
        <div class="premium-card">
            <div class="section-header">
                <div class="section-number">2</div>
                <h3 class="section-title">معلومات الموظف</h3>
            </div>

            <div class="employee-card">
                <div class="employee-grid">
                    <div class="employee-item">
                        <span class="employee-label"><i class="fa-solid fa-user icon"></i> الاسم الكامل</span>
                        <span class="employee-value">@Model.Employee.FullNameAr</span>
                    </div>
                    <div class="employee-item">
                        <span class="employee-label"><i class="fa-solid fa-building icon"></i> الإدارة / القسم</span>
                        <span class="employee-value">@Model.Employee.Department</span>
                    </div>
                    <div class="employee-item">
                        <span class="employee-label"><i class="fa-solid fa-briefcase icon"></i> المسمى الوظيفي</span>
                        <span class="employee-value">@Model.Employee.JobTitle</span>
                    </div>
                    <div class="employee-item">
                        <span class="employee-label"><i class="fa-solid fa-chart-pie icon"></i> إحصائيات الأجهزة</span>
                        <div class="stats-badges">
                            <span onclick="setRegionFilter('all')" class="stat-badge stat-badge-primary">
                                <i class="fa-solid fa-desktop icon"></i>
                                <span>@devices.Count إجمالي</span>
                            </span>
                            <span onclick="setRegionFilter('assigned')" class="stat-badge stat-badge-success">
                                <i class="fa-solid fa-circle-check icon"></i>
                                <span>@assigned.Count مرتبطة</span>
                            </span>
                            <span onclick="setRegionFilter('unassigned')" class="stat-badge stat-badge-info">
                                <i class="fa-solid fa-circle-minus icon"></i>
                                <span>@unassigned.Count غير مرتبطة</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.RegionGroups != null && Model.RegionGroups.Any())
        {
            <div class="premium-card">
                <div class="section-header">
                    <div class="section-number">3</div>
                    <h3 class="section-title">إدارة أجهزة البصمة</h3>
                </div>



                <div class="regions-container">
                    @for (int i = 0; i < Model.RegionGroups.Count; i++)
                    {
                        var g = Model.RegionGroups[i];
                        var collapseId = $"collapse_{i}";
                        var regionKey = "reg_" + i;
                        var hasAssigned = g.AssignedDevices > 0;
                        var hasUnassigned = (g.TotalDevices - g.AssignedDevices) > 0;

                        <div class="region-card"
                             data-has-assigned="@(hasAssigned ? "1" : "0")"
                             data-has-unassigned="@(hasUnassigned ? "1" : "0")">

                            <div class="region-header">
                                <div class="region-top">
                                    <div class="region-left">
                                        <div class="region-icon-wrapper"><i class="fa-solid fa-location-dot"></i></div>
                                        <div class="region-info" onclick="toggleRegionCollapse('@collapseId')">
                                            <h4>@g.RegionName</h4>
                                            <div class="region-meta">
                                                <span class="meta-badge">
                                                    <i class="fa-solid fa-desktop icon"></i>
                                                    <span>@g.TotalDevices أجهزة</span>
                                                </span>
                                                @{
                                                    var assignedCount = g.Devices.Count(x => x.IsEffectivelyAssigned);
                                                    var delegatedCount = g.Devices.Count(x => x.IsDelegated);
                                                }
                                                @if (assignedCount > 0)
                                                {
                                                    <span class="meta-badge success">
                                                        <i class="fa-solid fa-circle-check icon"></i>
                                                        <span>@assignedCount مرتبطة</span>
                                                    </span>
                                                }
                                                @if (delegatedCount > 0)
                                                {
                                                    <span class="meta-badge delegated">
                                                        <i class="fa-solid fa-clock-rotate-left icon"></i>
                                                        <span>@delegatedCount ندب</span>
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn-icon-toggle" onclick="toggleRegionCollapse('@collapseId')">
                                        <i class="fa-solid fa-chevron-down icon"></i>
                                    </button>
                                </div>
                            </div>

                            <div id="@collapseId" class="collapse">
                                <div class="region-options">
                                    <div class="options-title"><i class="fa-solid fa-gear icon"></i> اختر العملية المطلوبة</div>

                                    <div class="radio-options">
                                        <div class="radio-option">
                                            <input type="radio" name="operation_@regionKey" id="transfer_@regionKey" value="transfer" checked onchange="toggleDates('@regionKey', 'transfer')">
                                            <label for="transfer_@regionKey">
                                                <i class="fa-solid fa-right-left icon"></i>
                                                <span>نقل دائم</span>
                                            </label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" name="operation_@regionKey" id="delegate_@regionKey" value="delegate" onchange="toggleDates('@regionKey', 'delegate')">
                                            <label for="delegate_@regionKey">
                                                <i class="fa-solid fa-calendar-days icon"></i>
                                                <span>جدولة انتداب</span>
                                            </label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" name="operation_@regionKey" id="remove_@regionKey" value="remove" onchange="toggleDates('@regionKey', 'remove')">
                                            <label for="remove_@regionKey">
                                                <i class="fa-solid fa-fingerprint icon u-opacity-70"></i>
                                                <span>فك الارتباط</span>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="dates-row" id="dates_@regionKey">
                                        <div class="date-field">
                                            <label class="date-label">
                                                <i class="fa-solid fa-calendar-plus icon"></i>
                                                <span>تاريخ البداية</span>
                                            </label>
                                            <input type="text" class="date-input datepicker" id="startDate_@regionKey" placeholder="يوم/شهر/سنة" autocomplete="off">
                                        </div>
                                        <div class="date-field">
                                            <label class="date-label">
                                                <i class="fa-solid fa-calendar-xmark icon"></i>
                                                <span>تاريخ النهاية</span>
                                            </label>
                                            <input type="text" class="date-input datepicker" id="endDate_@regionKey" placeholder="يوم/شهر/سنة" autocomplete="off">
                                        </div>
                                    </div>

                                    <div class="warning-note" id="warning_@regionKey">
                                        <i class="fa-solid fa-triangle-exclamation icon"></i>
                                        <span>سيتم إلغاء الانتداب تلقائياً في التاريخ المحدد</span>
                                    </div>

                                   
                                </div>

                                <div class="devices-section">
                                    <div class="devices-section-title"><i class="fa-solid fa-fingerprint icon"></i> حدد الأجهزة</div>

                                    <div class="select-all-box">
                                        <input type="checkbox" id="check-@regionKey" class="select-all-region">
                                        <label for="check-@regionKey" class="select-all-label">تحديد جميع أجهزة المنطقة</label>
                                    </div>

                                    <div class="devices-grid">
                                        @foreach (var d in g.Devices)
                                        {
                                            var isSelected = selectedTerminals.Contains((d.DeviceId ?? "").Trim());

                                            <div class="device-card @((d.IsEffectivelyAssigned || isSelected) ? "selected" : "")"
                                                 data-is-assigned="@(d.IsEffectivelyAssigned ? "1" : "0")">

                                                <div class="device-checkbox" onclick="event.stopPropagation();">
                                                    <input type="checkbox"
                                                           class="device-chk"
                                                           value="@d.DeviceId"
                                                           id="chk-@d.DeviceId"
                                                           @((d.IsEffectivelyAssigned || isSelected) ? "checked" : "")
                                                           onclick="event.stopPropagation();"
                                                           onchange="updateDeviceSelection(this)"/>
                                                </div>

                                                <div class="c-employee-device-content">
                                                    <div class="c-employee-device-top">
                                                        <div class="device-icon"><i class="fa-solid fa-fingerprint"></i></div>

                                                        <div class="device-details">
                                                            <div class="device-name">@d.DeviceName</div>

                                                            <div class="c-employee-device-badges">
                                                                @if (d.IsAssigned)
                                                                {
                                                                    <span class="badge badge-success">مرتبط</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge badge-muted">متاح</span>
                                                                }

                                                                @if (d.IsDelegated)
                                                                {
                                                                    <span class="badge badge-info">ندب</span>
                                                                }
                                                            </div>

                                                            <div class="device-meta">
                                                                <i class="fa-solid fa-map-pin icon"></i>
                                                                <span>@(string.IsNullOrWhiteSpace(d.RegionName) ? "أجهزة غير مصنفة" : d.RegionName)</span>
                                                                <span>&bull;</span>
                                                                <span class="u-nowrap">رقم الجهاز: @d.DeviceId</span>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @if (d.IsDelegated && d.DelegationStartDate.HasValue && d.DelegationEndDate.HasValue)
                                                    {
                                                        <div class="c-employee-device-delegation">
                                                            <div class="c-employee-device-delegationHead">
                                                                <span class="c-employee-device-sectionTitle">حالة الندب</span>
                                                                @if (d.IsDelegatedActive)
                                                                {
                                                                    <span class="badge badge-success">ندب نشط</span>
                                                                }
                                                                else if (d.DelegationStatus == "Scheduled")
                                                                {
                                                                    <span class="badge badge-info">ندب مجدول</span>
                                                                }
                                                            </div>
                                                            <div class="text-muted c-employee-device-delegationDates">
                                                                من @d.DelegationStartDate.Value.ToString("dd/MM/yyyy")
                                                                إلى @d.DelegationEndDate.Value.ToString("dd/MM/yyyy")
                                                            </div>
                                                        </div>
                                                    }

                                                    @{
                                                        var showEndDelegation = d.IsDelegated && d.DelegationId.HasValue && d.IsDelegatedActive;
                                                        var showCancelDelegation = d.IsDelegated && d.DelegationId.HasValue && d.DelegationStatus == "Scheduled";
                                                        var showActions = d.IsAssigned || showEndDelegation || showCancelDelegation;
                                                    }

                                                    @if (showActions)
                                                    {
                                                        <div class="c-employee-device-actions" onclick="event.stopPropagation();">
                                                            <div class="u-flex u-gap-8 u-flex-wrap">
                                                                @if (d.IsAssigned)
                                                                {
                                                                    <form method="post" action="/employees/unassign" class="u-inline">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId"/>
                                                                        <input type="hidden" name="terminalId" value="@d.DeviceId"/>
                                                                        <button type="submit" class="btn btn-danger btn-sm u-nowrap">فك الارتباط</button>
                                                                    </form>
                                                                }

                                                                @if (showEndDelegation)
                                                                {
                                                                    <form method="post" action="/employees/end-delegation" class="u-inline">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId" />
                                                                        <input type="hidden" name="delegationId" value="@d.DelegationId.GetValueOrDefault()" />
                                                                        <button type="button" class="btn btn-danger btn-sm u-nowrap" onclick="confirmDelegationAction(this, 'هل أنت متأكد من إنهاء الندب؟')">إنهاء الندب</button>
                                                                    </form>
                                                                }
                                                                else if (showCancelDelegation)
                                                                {
                                                                    <form method="post" action="/employees/cancel-delegation" class="u-inline">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId" />
                                                                        <input type="hidden" name="delegationId" value="@d.DelegationId.GetValueOrDefault()" />
                                                                        <button type="button" class="btn btn-outline btn-sm u-nowrap" onclick="confirmDelegationAction(this, 'هل أنت متأكد من إلغاء الندب المجدول؟')">إلغاء الندب</button>
                                                                    </form>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        
                                    </div>
                                    @if (g.RegionId.HasValue && g.RegionId.Value > 0)
                                    {
                                        <button type="button" class="submit-region-btn" onclick="submitRegionWithOptions(@g.RegionId.Value, '@regionKey')">
                                            <i class="fa-solid fa-check icon"></i>
                                            <span>تطبيق على الأجهزة المحددة</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<div class="bulk-bar" id="bulkBar">
    <div class="bulk-info">
        <span class="pulse-indicator"></span>
        <div>
            <div class="bulk-count"><span id="selectedCount">0</span></div>
            <div class="bulk-label">جهاز محدد</div>
        </div>
    </div>
    <div class="bulk-actions">
        <button type="button" class="btn-bulk btn-bulk-success" onclick="submitBulk('AssignBulk')">
            <i class="fa-solid fa-link icon"></i>
            <span>ربط بالجملة</span>
        </button>
        <button type="button" class="btn-bulk btn-bulk-danger" onclick="submitBulk('UnassignBulk')">
            <i class="fa-solid fa-link-slash icon"></i>
            <span>فك الارتباط بالجملة</span>
        </button>
    </div>
</div>

<form id="bulkForm" method="post" class="is-hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" name="employeeId" value="@(Model?.Employee?.EmployeeId ?? 0)" />
    <div id="bulkInputsContainer"></div>
</form>

<form id="regionForm" method="post" class="is-hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" name="employeeId" value="@(Model?.Employee?.EmployeeId ?? 0)" />
    <input type="hidden" id="regionIdInput" name="regionId" value="" />
</form>

@section Scripts {
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    function updateBulkBar() {
        const selectedCount = document.querySelectorAll('.device-chk:checked').length;
        document.getElementById('selectedCount').textContent = selectedCount;
        const bar = document.getElementById('bulkBar');
        if (selectedCount > 0) {
            bar.classList.add('show');
        } else {
            bar.classList.remove('show');
        }
    }

    function updateDeviceSelection(checkbox) {
        const card = checkbox.closest('.device-card');
        if (checkbox.checked) {
            card.classList.add('selected');
        } else {
            card.classList.remove('selected');
        }
        updateBulkBar();
    }

    function toggleDeviceCheckbox(checkboxId) {
        const checkbox = document.getElementById(checkboxId);
        checkbox.checked = !checkbox.checked;
        updateDeviceSelection(checkbox);
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateBulkBar();

        // Initialize flatpickr for all date inputs with DD/MM/yyyy format
        flatpickr('.datepicker', {
            dateFormat: 'd/m/Y',
            altInput: true,
            altFormat: 'd/m/Y',
            allowInput: true,
            clickOpens: true,
            disableMobile: true
        });

        document.querySelectorAll('.select-all-region').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const regionCard = this.closest('.region-card');
                const deviceCheckboxes = regionCard.querySelectorAll('.device-chk');

                deviceCheckboxes.forEach(cb => {
                    cb.checked = this.checked;
                    updateDeviceSelection(cb);
                });
            });
        });
    });

    // Helper function to convert DD/MM/YYYY to YYYY-MM-DD for server
    function convertDateFormat(dateStr) {
        if (!dateStr) return '';
        const parts = dateStr.split('/');
        if (parts.length === 3) {
            return `${parts[2]}-${parts[1]}-${parts[0]}`;
        }
        return dateStr;
    }

    function toggleRegionCollapse(collapseId) {
        const element = document.getElementById(collapseId);
        const header = element.previousElementSibling;

        if (element.classList.contains('show')) {
            element.classList.remove('show');
            header.classList.remove('active');
        } else {
            element.classList.add('show');
            header.classList.add('active');
        }
    }

    function toggleDates(regionKey, operation) {
        const datesRow = document.getElementById('dates_' + regionKey);
        const warning = document.getElementById('warning_' + regionKey);

        if (operation === 'delegate') {
            datesRow.classList.add('show');
            warning.classList.add('show');
        } else {
            datesRow.classList.remove('show');
            warning.classList.remove('show');
        }
    }

    function submitRegionWithOptions(regionId, regionKey) {
        const operation = document.querySelector(`input[name="operation_${regionKey}"]:checked`).value;
        const startDateDisplay = document.getElementById(`startDate_${regionKey}`).value;
        const endDateDisplay = document.getElementById(`endDate_${regionKey}`).value;
        const startDate = convertDateFormat(startDateDisplay);
        const endDate = convertDateFormat(endDateDisplay);

        const regionCard = document.querySelector(`#check-${regionKey}`).closest('.region-card');
        const selectedDevices = Array.from(regionCard.querySelectorAll('.device-chk:checked'));

        if (selectedDevices.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'تنبيه',
                text: 'يرجى اختيار الأجهزة أولاً',
                confirmButtonColor: '#692f39',
                confirmButtonText: 'حسناً'
            });
            return;
        }

        if (operation === 'delegate' && (!startDateDisplay || !endDateDisplay)) {
            Swal.fire({
                icon: 'warning',
                title: 'تنبيه',
                text: 'يرجى تحديد تاريخ البداية والنهاية للانتداب',
                confirmButtonColor: '#692f39',
                confirmButtonText: 'حسناً'
            });
            return;
        }

        let actionName = '';
        let operationText = '';
        let operationIcon = '';

        if (operation === 'transfer') {
            actionName = 'AssignBulk';
            operationText = 'نقل دائم';
            operationIcon = '<i class="fa-solid fa-right-left text-maroon"></i>';
        } else if (operation === 'delegate') {
            actionName = 'DelegateRegion';
            operationText = `جدولة انتداب من ${startDateDisplay} إلى ${endDateDisplay}`;
            operationIcon = '<i class="fa-solid fa-calendar-days text-sky"></i>';
        } else if (operation === 'remove') {
            actionName = 'UnassignBulk';
            operationText = 'فك الارتباط';
            operationIcon = '<i class="fa-solid fa-fingerprint text-red-500 u-opacity-70"></i>';
        }

        Swal.fire({
            title: 'تأكيد العملية',
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--xl">${operationIcon}</div>
                    <p class="c-swal-lead">هل أنت متأكد من تنفيذ</p>
                    <p class="c-swal-title">${operationText}</p>
                    <p class="c-swal-count">${selectedDevices.length} جهاز</p>
                </div>`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '<i class="fa-solid fa-check"></i> تنفيذ',
            cancelButtonText: '<i class="fa-solid fa-xmark"></i> إلغاء'
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.getElementById('bulkForm');
                form.action = '/employees/' + actionName;

                const container = document.getElementById('bulkInputsContainer');
                container.innerHTML = '';

                selectedDevices.forEach(cb => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'terminalIds';
                    input.value = cb.value;
                    container.appendChild(input);
                });

                if (operation === 'delegate') {
                    let startInput = document.createElement('input');
                    startInput.type = 'hidden';
                    startInput.name = 'startDate';
                    startInput.value = startDate;
                    container.appendChild(startInput);

                    let endInput = document.createElement('input');
                    endInput.type = 'hidden';
                    endInput.name = 'endDate';
                    endInput.value = endDate;
                    container.appendChild(endInput);
                }

                form.submit();
            }
        });
    }

    function confirmDelegationAction(button, confirmText) {
        const form = button.closest('form');
        if (!form) return;

        Swal.fire({
            title: 'تأكيد العملية',
            text: confirmText || 'هل أنت متأكد؟',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'نعم',
            cancelButtonText: 'إلغاء'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    }

    function submitBulk(actionName) {
        const selectedIds = [];
        document.querySelectorAll('.device-chk:checked').forEach(cb => {
            selectedIds.push(cb.value);
        });

        if (selectedIds.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'تنبيه',
                text: 'يرجى اختيار الأجهزة أولاً',
                confirmButtonColor: '#692f39',
                confirmButtonText: 'حسناً'
            });
            return;
        }

        Swal.fire({
            title: 'تأكيد العملية',
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--lg"><i class="fa-solid fa-fingerprint text-maroon"></i></div>
                    <p class="c-swal-lead c-swal-lead--sm">هل أنت متأكد من تنفيذ العملية على</p>
                    <p class="c-swal-title c-swal-title--big">${selectedIds.length} جهاز؟</p>
                </div>`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '<i class="fa-solid fa-check"></i> تنفيذ',
            cancelButtonText: '<i class="fa-solid fa-xmark"></i> إلغاء'
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.getElementById('bulkForm');
                form.action = '/employees/' + actionName;

                const container = document.getElementById('bulkInputsContainer');
                container.innerHTML = '';
                selectedIds.forEach(id => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'terminalIds';
                    input.value = id;
                    container.appendChild(input);
                });

                form.submit();
            }
        });
    }

    function setRegionFilter(mode) {
        const pills = document.querySelectorAll('.region-filters .filter-pill');
        pills.forEach(p => p.classList.remove('active'));

        const activePill = document.querySelector(`.region-filters .filter-pill[data-filter="${mode}"]`);
        if (activePill) activePill.classList.add('active');

        const regionCards = document.querySelectorAll('.regions-container .region-card');

        regionCards.forEach(region => {
            const hasAssigned = region.getAttribute('data-has-assigned') === '1';
            const hasUnassigned = region.getAttribute('data-has-unassigned') === '1';

            let showRegion = true;
            if (mode === 'assigned') showRegion = hasAssigned;
            if (mode === 'unassigned') showRegion = hasUnassigned;

            region.style.display = showRegion ? '' : 'none';

            const devices = region.querySelectorAll('.device-card');
            devices.forEach(dev => {
                const isAssigned = dev.getAttribute('data-is-assigned') === '1';
                let showDevice = true;
                if (mode === 'assigned') showDevice = isAssigned;
                if (mode === 'unassigned') showDevice = !isAssigned;
                dev.classList.toggle('is-hidden', !showDevice);
            });

            if (showRegion) {
                const visibleDevices = region.querySelectorAll('.device-card:not(.is-hidden)');
                if (visibleDevices.length === 0) {
                    region.style.display = 'none';
                }
            }

            const selectAll = region.querySelector('.select-all-region');
            if (selectAll) selectAll.checked = false;
            updateBulkBar();
        });
    }

    document.addEventListener('change', function (e) {
        if (!e.target.classList.contains('select-all-region')) return;

        const selectAll = e.target;
        const regionCard = selectAll.closest('.region-card');
        if (!regionCard) return;

        const deviceCheckboxes = regionCard.querySelectorAll('.device-card:not(.is-hidden) .device-chk');

        deviceCheckboxes.forEach(chk => {
            chk.checked = selectAll.checked;
            if (typeof updateDeviceSelection === 'function') {
                updateDeviceSelection(chk);
            } else {
                const devCard = chk.closest('.device-card');
                if (devCard) devCard.classList.toggle('selected', chk.checked);
            }
        });

        updateBulkBar();
    });
        document.getElementById("autoAssignBtn")?.addEventListener("click", async () => {
        if (!confirm("هل تريد تحديث توزيع الأجهزة؟")) return;

        const res = await fetch("/api/terminals/auto-assign-regions", {
        method: "POST"
    });

        if (res.status === 403) {
        alert("غير مصرح لك (Admin فقط)");
        return;
    }

        const data = await res.json();
        alert(
        `تم التحديث بنجاح\n` +
        `عدد الأجهزة: ${data.totalDevices}\n` +
        `جديد: ${data.inserted}\n` +
        `تم تعديلها: ${data.updated}`
        );
    });

</script>
}
</div>


@model DevicesObservabilityViewModel

@{
    ViewData["Title"] = "لوحة نشاط الأجهزة";
}

@section Styles {
    <style>
        .obs-summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
        }

        .obs-summary-card {
            padding: 1.1rem 1.2rem;
            border-radius: 1rem;
            border: 1px solid rgba(15, 23, 42, 0.06);
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        }

        .obs-summary-card.is-neutral {
            background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }

        .obs-summary-card.is-success {
            background: linear-gradient(180deg, #effaf3 0%, #daf5e3 100%);
        }

        .obs-summary-card.is-inactive {
            background: linear-gradient(180deg, #f1f3f5 0%, #dee2e6 100%);
        }

        .obs-summary-card.is-week {
            background: linear-gradient(180deg, #fff8e1 0%, #ffe082 100%);
        }

        .badge-week {
            background-color: #e6a817;
            color: #fff;
            display: inline-block;
            padding: 0.25em 0.6em;
            border-radius: 0.4em;
            font-size: 0.85em;
            font-weight: 600;
        }

        .obs-summary-label {
            color: #6c757d;
            font-size: 0.92rem;
            margin-bottom: 0.4rem;
        }

        .obs-summary-value {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .obs-device-name {
            font-weight: 800;
        }

        .obs-device-meta {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 0.2rem;
        }

        .obs-problem-summary {
            font-size: 0.92rem;
            color: #495057;
            max-width: 420px;
        }
    </style>
}

<div class="content-card fade-in">
    <div class="page-header">
        <h1 class="page-title">
            <span class="page-title-icon">📡</span>
            <span>لوحة نشاط الأجهزة</span>
        </h1>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-error">
            <span>@Model.Error</span>
        </div>
    }

    <div class="obs-summary-grid mb-3">
        <div class="obs-summary-card is-neutral">
            <div class="obs-summary-label">إجمالي الأجهزة</div>
            <div class="obs-summary-value">@Model.TotalDevices</div>
        </div>
        <div class="obs-summary-card is-inactive">
            <div class="obs-summary-label">لا يوجد استخدام</div>
            <div class="obs-summary-value">@Model.NoActivityDevices</div>
        </div>
        <div class="obs-summary-card is-week">
            <div class="obs-summary-label">نشط هذا الأسبوع</div>
            <div class="obs-summary-value">@Model.ActiveThisWeekDevices</div>
        </div>
        <div class="obs-summary-card is-success">
            <div class="obs-summary-label">نشط اليوم</div>
            <div class="obs-summary-value">@Model.ActiveTodayDevices</div>
        </div>
    </div>

    <div class="u-flex u-items-center u-justify-between u-gap-12 u-mb-12">
        <h2 class="c-section-title">نشاط الأجهزة خلال آخر 7 أيام</h2>
        <span class="text-muted">
            يتم الاعتماد على سجل المصادقة فقط لقياس نشاط الاستخدام
        </span>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>الجهاز</th>
                    <th class="u-w-120">عنوان الشبكة</th>
                    <th class="u-w-120">نشاط الجهاز</th>
                    <th class="u-w-110">محاولات ناجحة</th>
                    <th class="u-w-110">محاولات فاشلة</th>
                    <th class="u-w-160">آخر نشاط</th>
                    <th>التفاصيل</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Devices.Any())
            {
                <tr>
                    <td colspan="7" class="u-text-center text-muted">لا توجد بيانات أجهزة متاحة حالياً.</td>
                </tr>
            }
            else
            {
                @foreach (var device in Model.Devices)
                {
                    <tr>
                        <td>
                            <div class="obs-device-name">@device.Name</div>
                            <div class="obs-device-meta">@device.TerminalId</div>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(device.Ip) ? "—" : device.Ip)</td>
                        <td>
                            @if (device.Status == "Active Today")
                            {
                                <span class="badge badge-success">نشط اليوم</span>
                            }
                            else if (device.Status == "Active This Week")
                            {
                                <span class="badge badge-week">نشط هذا الأسبوع</span>
                            }
                            else
                            {
                                <span class="badge badge-dark">لا يوجد استخدام</span>
                            }
                        </td>
                        <td>@device.ActivityCount</td>
                        <td>
                            @if (device.FailedAuthCount > 0)
                            {
                                <span style="color:#c0392b;font-weight:700;">@device.FailedAuthCount</span>
                            }
                            else
                            {
                                @:0
                            }
                        </td>
                        <td>@(device.LastSeen.HasValue ? device.LastSeen.Value.ToString("yyyy-MM-dd HH:mm") : "—")</td>
                        <td>
                            <div class="obs-problem-summary">
                                @(string.IsNullOrWhiteSpace(device.ProblemReason) ? "—" : device.ProblemReason)
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

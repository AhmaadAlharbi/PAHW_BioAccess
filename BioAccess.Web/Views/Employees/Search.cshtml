@model BioAccess.Web.DTOs.EmployeeDevicesScreenDto?
@{
    ViewData["Title"] = "بحث موظف";
    var toastType      = TempData["ToastType"] as string;
    var toastMsg       = TempData["ToastMsg"]  as string;
    var lastEmployeeId = TempData["LastEmployeeId"]?.ToString();
    var isAdmin        = Context.Session.GetString("IsAdmin") == "1";
    var devices        = Model?.Devices ?? new List<BioAccess.Web.DTOs.DeviceRowDto>();
    var assigned       = devices.Where(x => x.IsEffectivelyAssigned).ToList();
    var unassigned     = devices.Where(x => !x.IsEffectivelyAssigned).ToList();
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
}

<div class="employees-search-page"
     data-employee-id="@(Model?.Employee?.EmployeeId ?? 0)"
     data-employee-name="@(Model?.Employee?.FullNameAr ?? "")">

    @* ── Toast ─────────────────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(toastMsg))
    {
        var alertClass = toastType switch {
            "success" => "alert-success",
            "danger"  => "alert-danger",
            "warning" => "alert-warning",
            _         => "alert-info"
        };
        <div class="alert @alertClass d-flex align-items-center gap-2 mb-3" role="alert">
            @if (toastType == "success") { <i class="fa-solid fa-circle-check"></i> }
            else if (toastType == "danger") { <i class="fa-solid fa-circle-xmark"></i> }
            else if (toastType == "warning") { <i class="fa-solid fa-triangle-exclamation"></i> }
            else { <i class="fa-solid fa-circle-info"></i> }
            <span>@toastMsg</span>
        </div>
    }

    @* ── Card 1: Search ────────────────────────────────── *@
    <div class="content-card mb-3">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
            <h2 class="c-section-title">البحث عن موظف</h2>
            @* @if (isAdmin) *@
            @* { *@
            @*     <div class="c-admin-tools"> *@
            @*         <button type="button" class="btn btn-muted btn-sm c-admin-tools-toggle u-nowrap" onclick="toggleAdminTools()"> *@
            @*             <i class="fa-solid fa-screwdriver-wrench"></i> *@
            @*             <span>أدوات إدارية</span> *@
            @*         </button> *@
            @*         <div id="adminToolsPanel" class="c-admin-tools-panel is-hidden" aria-hidden="true"> *@
            @*             <div class="d-flex align-items-center gap-2 fw-bold text-maroon mb-3"> *@
            @*                 <i class="fa-solid fa-triangle-exclamation"></i> *@
            @*                 <span>إجراءات عامة (لا تخص موظفًا واحدًا)</span> *@
            @*             </div> *@
            @*             <div class="d-flex align-items-start justify-content-between gap-3 p-3 border rounded"> *@
            @*                 <div> *@
            @*                     <div class="fw-bold mb-1">إعادة توزيع الأجهزة تلقائيًا</div> *@
            @*                     <div class="text-muted small">قد يغيّر توزيع أجهزة كثيرة على المناطق. استخدمه فقط عند فقدان/تلف بيانات التوزيع.</div> *@
            @*                 </div> *@
            @*                 <button id="autoAssignBtn" type="button" class="btn btn-outline btn-sm u-nowrap"> *@
            @*                     <i class="fa-solid fa-rotate"></i> *@
            @*                     <span>تشغيل</span> *@
            @*                 </button> *@
            @*             </div> *@
            @*         </div> *@
            @*     </div> *@
            @* } *@
        </div>

        <form method="post" action="/employees/search">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2 align-items-end">
                <div class="flex-grow-1">
                    <label class="form-label fw-bold">الرقم الوظيفي للموظف</label>
                    <input type="number" name="employeeId" class="form-control"
                           placeholder="مثال: 7821"
                           value="@(Model?.Employee?.EmployeeId.ToString() ?? lastEmployeeId ?? "")"
                           required />
                </div>
                <button type="submit" class="btn btn-primary u-nowrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <span>بحث</span>
                </button>
            </div>
        </form>
    </div>

    @* ── Card 2: Employee info ──────────────────────────── *@
    @if (Model?.Employee != null)
    {
        <div class="content-card mb-3">
            <h2 class="c-section-title mb-3">معلومات الموظف</h2>

            <div class="row g-3 mb-3">
                <div class="col-sm-6 col-lg-3">
                    <div class="text-muted small mb-1">الاسم الكامل</div>
                    <div class="fw-bold">@Model.Employee.FullNameAr</div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="text-muted small mb-1">الإدارة / القسم</div>
                    <div class="fw-bold">@Model.Employee.Department</div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="text-muted small mb-1">المسمى الوظيفي</div>
                    <div class="fw-bold">@Model.Employee.JobTitle</div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="text-muted small mb-1">الرقم الوظيفي</div>
                    <div class="fw-bold text-maroon">@Model.Employee.EmployeeId</div>
                </div>
            </div>

            @* Filter pills — also act as device stats *@
            <div class="region-filters d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-sm btn-outline filter-pill active" data-filter="all"
                        onclick="setRegionFilter('all')">
                    <i class="fa-solid fa-desktop"></i> @devices.Count إجمالي
                </button>
                <button type="button" class="btn btn-sm btn-outline filter-pill" data-filter="assigned"
                        onclick="setRegionFilter('assigned')">
                    <i class="fa-solid fa-circle-check"></i> @assigned.Count مرتبطة
                </button>
                <button type="button" class="btn btn-sm btn-outline filter-pill" data-filter="unassigned"
                        onclick="setRegionFilter('unassigned')">
                    <i class="fa-solid fa-circle-minus"></i> @unassigned.Count غير مرتبطة
                </button>
            </div>
        </div>

        @* ── Card 3: Regions & Devices ──────────────────── *@
        @if (Model.RegionGroups != null && Model.RegionGroups.Any())
        {
            <div class="content-card">
                <h2 class="c-section-title mb-3">إدارة أجهزة البصمة</h2>

                <div class="regions-container">
                    @for (int i = 0; i < Model.RegionGroups.Count; i++)
                    {
                        var g          = Model.RegionGroups[i];
                        var collapseId = $"collapse_{i}";
                        var regionKey  = "reg_" + i;
                        var hasAssigned   = g.AssignedDevices > 0;
                        var hasUnassigned = (g.TotalDevices - g.AssignedDevices) > 0;
                        var assignedCount = g.Devices.Count(x => x.IsEffectivelyAssigned);
                        var delegatedCount = g.Devices.Count(x => x.IsDelegated);
                        var delegatedActiveTerminalIds = g.Devices
                            .Where(x => x.IsDelegatedActive && !string.IsNullOrWhiteSpace(x.DeviceId))
                            .Select(x => x.DeviceId!.Trim())
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();

                        <div class="region-card mb-3 border rounded"
                             data-has-assigned="@(hasAssigned ? "1" : "0")"
                             data-has-unassigned="@(hasUnassigned ? "1" : "0")">

                            @* Region header (clickable) *@
                            <div class="region-header d-flex align-items-center justify-content-between p-3 bg-light rounded-top"
                                 onclick="toggleRegionCollapse('@collapseId')" style="cursor:pointer">
                                <div class="d-flex align-items-center gap-3">
                                    <i class="fa-solid fa-location-dot text-maroon fs-5"></i>
                                    <div>
                                        <div class="fw-bold">@g.RegionName</div>
                                        <div class="d-flex gap-1 flex-wrap mt-1">
                                            <span class="badge bg-secondary">@g.TotalDevices أجهزة</span>
                                            @if (assignedCount > 0)
                                            {
                                                <span class="badge bg-success">@assignedCount مرتبطة</span>
                                            }
                                            @if (delegatedCount > 0)
                                            {
                                                <span class="badge bg-warning text-dark">@delegatedCount ندب</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2" onclick="event.stopPropagation();">
                                    @if (delegatedActiveTerminalIds.Count > 0)
                                    {
                                        <form method="post" action="/employees/end-delegation" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId" />
                                            @foreach (var terminalId in delegatedActiveTerminalIds)
                                            {
                                                <input type="hidden" name="terminalIds" value="@terminalId" />
                                            }
                                            <button type="button" class="btn btn-danger btn-sm u-nowrap"
                                                    onclick="confirmDelegationScopeAction(this, 'region')">
                                                إنهاء الندب لكل أجهزة المنطقة
                                            </button>
                                        </form>
                                    }
                                    <i class="fa-solid fa-chevron-down text-muted region-chevron"></i>
                                </div>
                            </div>

                            @* Collapse body *@
                            <div id="@collapseId" class="rgn-collapse p-3">

                                @* Select all *@
                                <div class="form-check bg-light border rounded p-3 mb-3 region-select-all">
                                    <input class="form-check-input select-all-region" type="checkbox"
                                           id="selectAllRegion_@regionKey" />
                                    <label class="form-check-label fw-semibold" for="selectAllRegion_@regionKey">
                                        تحديد جميع أجهزة المنطقة
                                    </label>
                                </div>

                                @* Device grid *@
                                <div class="row g-2 devices-grid">
                                    @foreach (var d in g.Devices)
                                    {
                                        var terminalId = (d.DeviceId ?? "").Trim();
                                        var regionName = string.IsNullOrWhiteSpace(d.RegionName) ? "أجهزة غير مصنفة" : d.RegionName;

                                        var stateText =
                                            d.IsDelegatedActive ? "مرتبط عبر ندب"
                                            : (d.IsDelegated && d.DelegationStatus == "Scheduled") ? "ندب مجدول"
                                            : d.IsAssigned ? "مرتبط فعليًا"
                                            : "غير مرتبط";

                                        var stateClass =
                                            d.IsDelegatedActive ? "is-delegated-active"
                                            : (d.IsDelegated && d.DelegationStatus == "Scheduled") ? "is-delegated-scheduled"
                                            : d.IsAssigned ? "is-assigned"
                                            : "is-unassigned";

                                        var stateKey =
                                            d.IsDelegatedActive ? "delegated_active"
                                            : (d.IsDelegated && d.DelegationStatus == "Scheduled") ? "delegated_scheduled"
                                            : d.IsAssigned ? "assigned"
                                            : "unassigned";

                                        <div class="col-md-6 col-xl-4">
                                            <div class="device-card"
                                                 data-is-assigned="@(d.IsEffectivelyAssigned ? "1" : "0")"
                                                 data-state="@stateText"
                                                 data-state-key="@stateKey"
                                                 data-terminal-id="@terminalId"
                                                 data-device-name="@d.DeviceName"
                                                 data-delegation-id="@(d.DelegationId?.ToString() ?? "")"
                                                 data-delegation-status="@(d.DelegationStatus ?? "")"
                                                 data-delegation-start="@(d.DelegationStartDate?.ToString("dd/MM/yyyy") ?? "")"
                                                 data-delegation-end="@(d.DelegationEndDate?.ToString("dd/MM/yyyy") ?? "")">

                                                <div class="d-flex align-items-start gap-2">
                                                    <input type="checkbox"
                                                           class="form-check-input device-chk flex-shrink-0 mt-1"
                                                           value="@terminalId"
                                                           id="chk-@terminalId"
                                                           onclick="event.stopPropagation();"
                                                           onchange="updateDeviceSelection(this)" />

                                                    <div class="flex-grow-1" style="min-width:0">
                                                        <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                                                            <div class="fw-bold text-truncate">@d.DeviceName</div>
                                                            <span class="c-employee-device-state @stateClass">@stateText</span>
                                                        </div>

                                                        <div class="text-muted small mb-1">
                                                            <i class="fa-solid fa-map-pin"></i> @regionName
                                                            &bull;
                                                            <i class="fa-solid fa-hashtag"></i> @terminalId
                                                        </div>

                                                        <div class="small mb-1">
                                                            @if (d.IsOnline)
                                                            {
                                                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                                                    <i class="fa-solid fa-circle-check"></i> Online
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                                                    <i class="fa-solid fa-circle-xmark"></i> Offline
                                                                </span>
                                                            }
                                                            <span class="text-muted ms-2">@d.IsOnline</span>
                                                        </div>

                                                        @if (d.IsDelegated && d.DelegationStartDate.HasValue && d.DelegationEndDate.HasValue)
                                                        {
                                                            <div class="text-muted small">
                                                                <i class="fa-regular fa-calendar"></i>
                                                                من @d.DelegationStartDate.Value.ToString("dd/MM/yyyy")
                                                                &rarr;
                                                                إلى @d.DelegationEndDate.Value.ToString("dd/MM/yyyy")
                                                            </div>
                                                        }

                                                        @* Per-device delegation actions *@
                                                        @if (d.IsDelegatedActive && d.DelegationId.HasValue)
                                                        {
                                                            <div class="mt-2 pt-2 border-top" onclick="event.stopPropagation();">
                                                                <form method="post" action="/employees/end-delegation" class="d-inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId" />
                                                                    <input type="hidden" name="terminalIds" value="@terminalId" />
                                                                    <button type="button" class="btn btn-danger btn-sm u-nowrap"
                                                                            onclick="confirmDelegationScopeAction(this, 'device')">
                                                                        إنهاء الندب
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        }
                                                        else if (d.IsDelegated && d.DelegationStatus == "Scheduled" && d.DelegationId.HasValue)
                                                        {
                                                            <div class="mt-2 pt-2 border-top" onclick="event.stopPropagation();">
                                                                <form method="post" action="/employees/cancel-delegation" class="d-inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="employeeId" value="@Model.Employee.EmployeeId" />
                                                                    <input type="hidden" name="delegationId" value="@d.DelegationId.GetValueOrDefault()" />
                                                                    <button type="button" class="btn btn-outline btn-sm u-nowrap"
                                                                            onclick="confirmDelegationCardAction(this, 'cancel')">
                                                                        إلغاء الندب
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    }
                </div>
            </div>
        }
    }

    @* ── Bulk action bar (fixed floating) ──────────────── *@
    <div class="bulk-bar" id="bulkBar">
        <div class="bulk-info">
            <span class="pulse-indicator"></span>
            <div>
                <div class="bulk-count"><span id="selectedCount">0</span></div>
                <div class="bulk-label" id="selectedLabel">تم تحديد 0 جهاز</div>
            </div>
        </div>
        <div class="bulk-actions bulk-actions--controls">
            <select id="bulkOperation" class="bulk-select" onchange="onBulkOperationChange()">
                <option value="assign">ربط دائم</option>
                <option value="unassign">فك الربط</option>
                <option value="delegate">إنشاء ندب</option>
                <option value="endDelegation">إنهاء الندب</option>
            </select>
            <div id="bulkDates" class="bulk-dates d-flex gap-2 is-hidden" aria-hidden="true">
                <input id="bulkStartDate" type="text" class="date-input datepicker" placeholder="تاريخ البداية" autocomplete="off" />
                <input id="bulkEndDate"   type="text" class="date-input datepicker" placeholder="تاريخ النهاية"  autocomplete="off" />
            </div>
            <button id="bulkExecuteBtn" type="button" class="btn-bulk btn-bulk-success" onclick="bulkExecute()">
                <i class="fa-solid fa-check"></i>
                <span>تنفيذ</span>
            </button>
            <button id="bulkClearSelectionBtn" type="button" class="btn-bulk btn-bulk-danger" onclick="clearSelection()">
                <i class="fa-solid fa-xmark"></i>
                <span>إلغاء</span>
            </button>
        </div>
    </div>

    @* Hidden bulk submit form *@
    <form id="bulkForm" method="post" class="is-hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" name="employeeId" value="@(Model?.Employee?.EmployeeId ?? 0)" />
        <div id="bulkInputsContainer"></div>
    </form>

</div>

@section Scripts {
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    function getEmployeeText() {
        const page = document.querySelector('.employees-search-page');
        const employeeId = (page?.dataset?.employeeId || '').trim();
        const employeeName = (page?.dataset?.employeeName || '').trim();
        if (employeeName && employeeId && employeeId !== '0') return `${employeeName} (${employeeId})`;
        if (employeeId && employeeId !== '0') return `الموظف رقم ${employeeId}`;
        return 'الموظف';
    }

    function getSelectedCards() {
        return Array.from(document.querySelectorAll('.device-chk:checked'))
            .map(cb => cb.closest('.device-card'))
            .filter(Boolean);
    }

    function getSelectedTerminalIds() {
        return getSelectedCards()
            .map(card => (card.dataset.terminalId || '').trim())
            .filter(Boolean);
    }

    function getSelectedStateKeys() {
        return getSelectedCards()
            .map(c => (c.dataset.stateKey || '').trim())
            .filter(Boolean);
    }

    function getUnique(items) {
        return Array.from(new Set(items.filter(Boolean)));
    }

    function clearSelection() {
        document.querySelectorAll('.device-chk:checked').forEach(cb => {
            cb.checked = false;
            const card = cb.closest('.device-card');
            if (card) card.classList.remove('selected');
        });
        updateBulkBar();
    }

    function updateBulkBar() {
        const selectedCount = document.querySelectorAll('.device-chk:checked').length;
        document.getElementById('selectedCount').textContent = String(selectedCount);
        document.getElementById('selectedLabel').textContent = `تم تحديد ${selectedCount} جهاز`;

        const bar = document.getElementById('bulkBar');
        bar.classList.toggle('show', selectedCount > 0);
        bar.classList.toggle('is-single', selectedCount === 1);

        updateBulkControls();
    }

    function updateDeviceSelection(checkbox) {
        const card = checkbox.closest('.device-card');
        if (checkbox.checked) {
            card.classList.add('selected');
        } else {
            card.classList.remove('selected');
        }
        updateBulkBar();
    }

    function toggleDeviceCheckbox(checkboxId) {
        const checkbox = document.getElementById(checkboxId);
        checkbox.checked = !checkbox.checked;
        updateDeviceSelection(checkbox);
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateBulkBar();
        onBulkOperationChange();

        flatpickr('.datepicker', {
            dateFormat: 'd/m/Y',
            altInput: true,
            altFormat: 'd/m/Y',
            allowInput: true,
            clickOpens: true,
            disableMobile: true
        });

        document.getElementById('bulkStartDate')?.addEventListener('change', updateBulkControls);
        document.getElementById('bulkEndDate')?.addEventListener('change', updateBulkControls);
    });

    function convertDateFormat(dateStr) {
        if (!dateStr) return '';
        const parts = dateStr.split('/');
        if (parts.length === 3) return `${parts[2]}-${parts[1]}-${parts[0]}`;
        return dateStr;
    }

    function toggleRegionCollapse(collapseId) {
        const element = document.getElementById(collapseId);
        const header = element.previousElementSibling;

        if (element.classList.contains('show')) {
            element.classList.remove('show');
            header.classList.remove('active');
        } else {
            element.classList.add('show');
            header.classList.add('active');
        }
    }

    function onBulkOperationChange() {
        const op = (document.getElementById('bulkOperation')?.value || '').trim();
        const dates = document.getElementById('bulkDates');
        const showDates = op === 'delegate';
        dates.classList.toggle('is-hidden', !showDates);
        dates.setAttribute('aria-hidden', String(!showDates));
        updateBulkControls();
    }

    function updateBulkControls() {
        const op = (document.getElementById('bulkOperation')?.value || '').trim();
        const btn = document.getElementById('bulkExecuteBtn');
        const count = getSelectedTerminalIds().length;

        let canRun = count > 0;
        const stateKeys = getSelectedStateKeys();
        const uniqueStates = getUnique(stateKeys);

        if (canRun && uniqueStates.length > 1) canRun = false;

        if (op === 'delegate') {
            const sd = (document.getElementById('bulkStartDate')?.value || '').trim();
            const ed = (document.getElementById('bulkEndDate')?.value || '').trim();
            canRun = canRun && !!sd && !!ed;
        }

        if (canRun && uniqueStates.length === 1) {
            const s = uniqueStates[0];
            if (op === 'assign')   canRun = (s === 'unassigned');
            if (op === 'unassign') canRun = (s === 'assigned' || s === 'delegated_active');
            if (op === 'delegate') canRun = (s === 'unassigned' || s === 'assigned');
            if (op === 'endDelegation') canRun = (s === 'delegated_active');
        }

        btn.disabled = !canRun;
        btn.classList.toggle('is-disabled', !canRun);
        const label = btn.querySelector('span');
        if (label) {
            label.textContent = op === 'endDelegation' ? `إنهاء الندب لـ (${count}) جهاز` : 'تنفيذ';
        }
    }

    function fillAndSubmitBulkForm(actionUrl, fields) {
        const form = document.getElementById('bulkForm');
        const container = document.getElementById('bulkInputsContainer');
        form.action = actionUrl;
        container.innerHTML = '';

        (fields || []).forEach(f => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = f.name;
            input.value = f.value;
            container.appendChild(input);
        });

        form.submit();
    }

    async function bulkExecute() {
        const op = (document.getElementById('bulkOperation')?.value || '').trim();
        const selectedIds = getSelectedTerminalIds();
        if (selectedIds.length === 0) {
            await Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى تحديد جهاز واحد على الأقل', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
            return;
        }

        const stateKeys = getSelectedStateKeys();
        const uniqueStates = getUnique(stateKeys);
        if (uniqueStates.length > 1) {
            await Swal.fire({ icon: 'warning', title: 'لا يمكن التنفيذ', text: 'الأجهزة المحددة ليست بنفس الحالة ولا يمكن تنفيذ العملية عليها معًا.', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
            return;
        }

        const selectionState = uniqueStates[0] || '';
        const employeeText = getEmployeeText();
        const count = selectedIds.length;
        const startDisplay = (document.getElementById('bulkStartDate')?.value || '').trim();
        const endDisplay   = (document.getElementById('bulkEndDate')?.value   || '').trim();

        let title = 'مراجعة قبل التنفيذ';
        let opText = '';
        let iconHtml = '<i class="fa-solid fa-fingerprint text-maroon"></i>';
        let extraMeta = '';
        let note = '';
        let actionUrl = '';
        let fields = [];

        if (op === 'assign') {
            if (selectionState !== 'unassigned') {
                await Swal.fire({ icon: 'warning', title: 'لا يمكن التنفيذ', text: 'عملية الربط الدائم متاحة فقط للأجهزة غير المرتبطة.', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
                return;
            }
            opText = 'ربط دائم';
            actionUrl = '/employees/AssignBulk';
            fields = selectedIds.map(x => ({ name: 'terminalIds', value: x }));
        } else if (op === 'unassign') {
            if (!(selectionState === 'assigned' || selectionState === 'delegated_active')) {
                await Swal.fire({ icon: 'warning', title: 'لا يمكن التنفيذ', text: 'عملية فك الربط متاحة فقط للأجهزة المرتبطة فعليًا أو المرتبطة عبر ندب.', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
                return;
            }
            opText = 'فك الربط';
            actionUrl = '/employees/UnassignBulk';
            fields = selectedIds.map(x => ({ name: 'terminalIds', value: x }));
            iconHtml = '<i class="fa-solid fa-link-slash text-red-500"></i>';
        } else if (op === 'delegate') {
            if (!(selectionState === 'unassigned' || selectionState === 'assigned')) {
                await Swal.fire({ icon: 'warning', title: 'لا يمكن التنفيذ', text: 'إنشاء الندب متاح فقط للأجهزة غير المرتبطة أو المرتبطة فعليًا (بدون ندب).', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
                return;
            }
            opText = 'إنشاء ندب';
            actionUrl = '/employees/DelegateRegion';
            if (!startDisplay || !endDisplay) {
                await Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى تحديد تاريخ البداية والنهاية للندب', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
                return;
            }
            const start = convertDateFormat(startDisplay);
            const end   = convertDateFormat(endDisplay);
            fields = selectedIds.map(x => ({ name: 'terminalIds', value: x }));
            fields.push({ name: 'startDate', value: start });
            fields.push({ name: 'endDate',   value: end });
            extraMeta = `<div>الفترة: <strong>${startDisplay} → ${endDisplay}</strong></div>`;
            iconHtml = '<i class="fa-solid fa-calendar-days text-sky"></i>';
            note = 'ملاحظة: سيتم إنهاء الندب تلقائيًا في تاريخ النهاية.';
        } else if (op === 'endDelegation') {
            if (selectionState !== 'delegated_active') {
                await Swal.fire({ icon: 'warning', title: 'لا يمكن التنفيذ', text: 'إنهاء الندب متاح فقط للأجهزة المرتبطة عبر ندب نشط.', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
                return;
            }
            opText = 'إنهاء الندب';
            actionUrl = '/employees/end-delegation';
            fields = selectedIds.map(x => ({ name: 'terminalIds', value: x }));
            iconHtml = '<i class="fa-solid fa-ban text-red-500"></i>';
            note = 'سيتم إنهاء الندب فقط للأجهزة المحددة.';
        } else {
            await Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى اختيار العملية.', confirmButtonColor: '#692f39', confirmButtonText: 'حسناً' });
            return;
        }

        const confirmResult = await Swal.fire({
            title,
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--lg">${iconHtml}</div>
                    <p class="c-swal-lead c-swal-lead--sm">${opText}</p>
                    <p class="c-swal-title">${employeeText}</p>
                    <div class="c-swal-meta">
                        <div>عدد الأجهزة المحددة: <strong>${count}</strong></div>
                        ${extraMeta}
                    </div>
                    ${note ? `<p class="c-swal-note">${note}</p>` : ''}
                </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '<i class="fa-solid fa-check"></i> تنفيذ',
            cancelButtonText:  '<i class="fa-solid fa-xmark"></i> إلغاء'
        });

        if (!confirmResult.isConfirmed) return;
        fillAndSubmitBulkForm(actionUrl, fields);
    }

    async function confirmDelegationScopeAction(button, scope) {
        const form = button.closest('form');
        if (!form) return;

        const employeeText = getEmployeeText();
        const terminalIds = Array.from(form.querySelectorAll('input[name="terminalIds"]'))
            .map(input => (input.value || '').trim())
            .filter(Boolean);
        const card = button.closest('.device-card');
        const regionCard = button.closest('.region-card');
        const deviceName  = (card?.dataset?.deviceName   || '').trim();
        const terminalId  = (card?.dataset?.terminalId   || '').trim();
        const start       = (card?.dataset?.delegationStart || '').trim();
        const end         = (card?.dataset?.delegationEnd   || '').trim();
        const regionName  = (regionCard?.querySelector('.fw-bold')?.textContent || '').trim();
        const datesText  = (start && end) ? `${start} → ${end}` : '';
        const count = terminalIds.length;

        let metaHtml = '';
        if (scope === 'device') {
            metaHtml = `
                <div>الجهاز: <strong>${deviceName || terminalId || '-'}</strong></div>
                ${terminalId ? `<div>TerminalId: <strong>${terminalId}</strong></div>` : ''}
                ${datesText  ? `<div>الفترة: <strong>${datesText}</strong></div>` : ''}
            `;
        } else {
            metaHtml = `
                <div>عدد الأجهزة: <strong>${count}</strong></div>
                ${regionName ? `<div>المنطقة: <strong>${regionName}</strong></div>` : ''}
            `;
        }

        const confirmResult = await Swal.fire({
            title: 'تأكيد العملية',
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--lg"><i class="fa-solid fa-triangle-exclamation text-maroon"></i></div>
                    <p class="c-swal-lead c-swal-lead--sm">إنهاء الندب</p>
                    <p class="c-swal-title">${employeeText}</p>
                    <div class="c-swal-meta">${metaHtml}</div>
                </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'نعم',
            cancelButtonText:  'إلغاء'
        });

        if (confirmResult.isConfirmed) form.submit();
    }

    async function confirmDelegationCardAction(button, action) {
        if (action !== 'cancel') {
            await confirmDelegationScopeAction(button, 'device');
            return;
        }

        const form = button.closest('form');
        if (!form) return;

        const card = button.closest('.device-card');
        const employeeText = getEmployeeText();
        const deviceName  = (card?.dataset?.deviceName   || '').trim();
        const terminalId  = (card?.dataset?.terminalId   || '').trim();
        const start       = (card?.dataset?.delegationStart || '').trim();
        const end         = (card?.dataset?.delegationEnd   || '').trim();
        const datesText  = (start && end) ? `${start} → ${end}` : '';

        const confirmResult = await Swal.fire({
            title: 'تأكيد العملية',
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--lg"><i class="fa-solid fa-triangle-exclamation text-maroon"></i></div>
                    <p class="c-swal-lead c-swal-lead--sm">إلغاء الندب</p>
                    <p class="c-swal-title">${employeeText}</p>
                    <div class="c-swal-meta">
                        <div>الجهاز: <strong>${deviceName || terminalId || '-'}</strong></div>
                        ${terminalId ? `<div>TerminalId: <strong>${terminalId}</strong></div>` : ''}
                        ${datesText  ? `<div>الفترة: <strong>${datesText}</strong></div>` : ''}
                    </div>
                </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'نعم',
            cancelButtonText:  'إلغاء'
        });

        if (confirmResult.isConfirmed) form.submit();
    }

    function setRegionFilter(mode) {
        const pills = document.querySelectorAll('.region-filters .filter-pill');
        pills.forEach(p => p.classList.remove('active'));

        const activePill = document.querySelector(`.region-filters .filter-pill[data-filter="${mode}"]`);
        if (activePill) activePill.classList.add('active');

        const regionCards = document.querySelectorAll('.regions-container .region-card');

        regionCards.forEach(region => {
            const hasAssigned   = region.getAttribute('data-has-assigned')   === '1';
            const hasUnassigned = region.getAttribute('data-has-unassigned') === '1';

            let showRegion = true;
            if (mode === 'assigned')   showRegion = hasAssigned;
            if (mode === 'unassigned') showRegion = hasUnassigned;

            region.classList.toggle('is-hidden', !showRegion);

            const devCards = region.querySelectorAll('.device-card');
            devCards.forEach(dev => {
                const isAssigned = dev.getAttribute('data-is-assigned') === '1';
                let showDevice = true;
                if (mode === 'assigned')   showDevice = isAssigned;
                if (mode === 'unassigned') showDevice = !isAssigned;
                dev.classList.toggle('is-hidden', !showDevice);
            });

            if (showRegion) {
                const visibleDevices = region.querySelectorAll('.device-card:not(.is-hidden)');
                region.classList.toggle('is-hidden', visibleDevices.length === 0);
            }

            const selectAll = region.querySelector('.select-all-region');
            if (selectAll) selectAll.checked = false;
            updateBulkBar();
        });
    }

    document.addEventListener('change', function (e) {
        if (!e.target.classList.contains('select-all-region')) return;
        const selectAll  = e.target;
        const regionCard = selectAll.closest('.region-card');
        if (!regionCard) return;
        const deviceCheckboxes = regionCard.querySelectorAll('.device-card:not(.is-hidden) .device-chk');
        deviceCheckboxes.forEach(chk => {
            chk.checked = selectAll.checked;
            if (typeof updateDeviceSelection === 'function') {
                updateDeviceSelection(chk);
            } else {
                const devCard = chk.closest('.device-card');
                if (devCard) devCard.classList.toggle('selected', chk.checked);
            }
        });
        updateBulkBar();
    });

    document.getElementById("autoAssignBtn")?.addEventListener("click", async () => {
        const confirmResult = await Swal.fire({
            title: 'تأكيد إجراء إداري',
            html: `<div class="c-swal-body">
                    <div class="c-swal-icon c-swal-icon--lg"><i class="fa-solid fa-triangle-exclamation text-maroon"></i></div>
                    <p class="c-swal-title">إعادة توزيع الأجهزة تلقائيًا</p>
                    <p class="c-swal-lead c-swal-lead--sm">هذا الإجراء عام وقد يغيّر توزيع أجهزة كثيرة على المناطق.</p>
                    <p class="c-swal-note">استخدمه فقط عند فقدان أو تلف بيانات التوزيع.</p>
                </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#692f39',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'تشغيل',
            cancelButtonText:  'إلغاء'
        });

        if (!confirmResult.isConfirmed) return;

        const res = await fetch("/api/terminals/auto-assign-regions", { method: "POST" });

        if (res.status === 403) {
            await Swal.fire({ icon: 'error', title: 'غير مصرح', text: 'غير مصرح لك (Admin فقط).' });
            return;
        }

        const data = await res.json();
        await Swal.fire({
            icon: 'success',
            title: 'تم التنفيذ',
            html: `<div class="c-swal-body">
                    <p class="c-swal-title">تمت إعادة بناء توزيع الأجهزة</p>
                    <div class="c-swal-meta">
                        <div>عدد الأجهزة: <strong>${data.totalDevices ?? '-'}</strong></div>
                        <div>جديد: <strong>${data.inserted ?? data.newlyAssigned ?? '-'}</strong></div>
                        <div>تم تعديلها: <strong>${data.updated ?? data.updatedRegions ?? '-'}</strong></div>
                    </div>
                </div>`,
            confirmButtonColor: '#692f39'
        });
    });

    function toggleAdminTools() {
        const panel = document.getElementById('adminToolsPanel');
        if (!panel) return;
        const isHidden = panel.classList.contains('is-hidden');
        panel.classList.toggle('is-hidden', !isHidden);
        panel.setAttribute('aria-hidden', String(!isHidden));
    }
</script>
}

@{
    var currentEmpId   = Context.Session.GetString("EmpId")   ?? "";
    var currentEmpName = Context.Session.GetString("EmpName") ?? "غير مسجل";
    var isAdmin        = Context.Session.GetString("IsAdmin")  == "1";
    var isLoggedIn     = Context.Session.GetString("EmpName")  != null;
    var controller     = ViewContext.RouteData.Values["controller"]?.ToString();
    var action         = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة البصمات</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
@if (isLoggedIn)
{
    <div class="app-layout">

        @* Sidebar (appears on RIGHT in RTL flex flow) *@
        <aside class="app-sidebar" id="appSidebar">

            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
                    <img src="https://www.pahw.gov.kw/images/PAHW-Logo.png" alt="شعار المؤسسة" class="sidebar-logo" />
                </a>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index" class="sidebar-nav-item @(controller == "Dashboard" ? "active" : "")">
                    <span class="sidebar-nav-icon">📊</span>
                    <span>لوحة التحكم</span>
                </a>
                <a asp-controller="Employees" asp-action="Search" class="sidebar-nav-item @(action == "Search" && controller == "Employees" ? "active" : "")">
                    <span class="sidebar-nav-icon">🔍</span>
                    <span>بحث موظف</span>
                </a>
                @if (isAdmin)
                {
                    <a asp-controller="AllowedUsers" asp-action="Index" class="sidebar-nav-item @(controller == "AllowedUsers" || controller == "Allowlist" ? "active" : "")">
                        <span class="sidebar-nav-icon">👥</span>
                        <span>قائمة الصلاحيات</span>
                    </a>
                    <div class="sidebar-divider"></div>
                    <a asp-controller="Terminals" asp-action="Index" class="sidebar-nav-item @(controller == "Terminals" ? "active" : "")">
                        <span class="sidebar-nav-icon">🗺️</span>
                        <span>المناطق والأجهزة</span>
                    </a>
                    <a asp-controller="AdminObservability" asp-action="Devices" class="sidebar-nav-item @(controller == "AdminObservability" && action == "Devices" ? "active" : "")">
                        <span class="sidebar-nav-icon">📡</span>
                        <span>نشاط الأجهزة</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        @(currentEmpName.Length > 0 ? currentEmpName.Substring(0, 1) : "م")
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">@currentEmpName</span>
                        <span class="sidebar-user-role">@(isAdmin ? "⭐ مدير" : currentEmpId)</span>
                    </div>
                </div>
                <form asp-controller="Home" asp-action="Logout" method="post" class="sidebar-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-nav-item sidebar-logout-btn" title="تسجيل الخروج" aria-label="تسجيل الخروج">
                        <span class="sidebar-nav-icon sidebar-logout-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/>
                                <line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                        </span>
                        <span>تسجيل الخروج</span>
                    </button>
                </form>
            </div>

        </aside>

        @* Main content *@
        <div class="app-main">

            <header class="app-topbar">
                <button class="app-sidebar-toggle" onclick="toggleSidebar()" aria-label="تبديل القائمة">☰</button>
                <span class="app-topbar-title">@ViewData["Title"]</span>
            </header>

            <main class="app-content">
                @RenderBody()
            </main>

        </div>

    </div>
}
else
{
    @* Login / unauthenticated pages: full-page layout with decorative background *@
    <div class="bg-particles">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>
    <main class="main-container">
        @RenderBody()
    </main>
}

<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@RenderSection("Scripts", required: false)

<script>
    function toggleSidebar() {
        var s = document.getElementById('appSidebar');
        if (s) s.classList.toggle('is-open');
    }
    document.addEventListener('click', function (e) {
        if (window.innerWidth > 900) return;
        var s = document.getElementById('appSidebar');
        if (!s || !s.classList.contains('is-open')) return;
        if (!s.contains(e.target) && !e.target.closest('.app-sidebar-toggle')) {
            s.classList.remove('is-open');
        }
    });

    // Auto-dismiss alerts: adds close button + 4-second fade-out
    (function () {
        function dismissAlert(el) {
            el.classList.add('alert-dismissing');
            setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 380);
        }
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.app-content .alert').forEach(function (a) {
                a.style.paddingLeft = '2.5rem';
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'js-alert-close';
                btn.setAttribute('aria-label', 'إغلاق');
                btn.textContent = '×';
                btn.addEventListener('click', function () { dismissAlert(a); });
                a.appendChild(btn);
                setTimeout(function () { dismissAlert(a); }, 4000);
            });
        });
    }());
</script>
</body>
</html>

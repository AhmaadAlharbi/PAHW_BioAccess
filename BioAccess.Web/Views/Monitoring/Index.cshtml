@{
    ViewData["Title"] = "Monitoring";
}

@section Styles {
    <style>
        .monitoring-hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.25rem;
            border: 1px solid rgba(105, 47, 57, 0.12);
            border-radius: 1rem;
            background: linear-gradient(135deg, rgba(105, 47, 57, 0.06), rgba(255, 243, 205, 0.5));
        }

        .monitoring-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1rem;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.95rem;
        }

        .monitoring-status-badge.is-healthy {
            background: rgba(25, 135, 84, 0.12);
            color: #146c43;
        }

        .monitoring-status-badge.is-warning {
            background: rgba(255, 193, 7, 0.18);
            color: #997404;
        }

        .monitoring-status-badge.is-degraded {
            background: rgba(220, 53, 69, 0.12);
            color: #b02a37;
        }

        .monitoring-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
        }

        .monitoring-metric-card {
            border: 0;
            border-radius: 1rem;
            padding: 1.1rem;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        }

        .monitoring-metric-card.is-success {
            background: linear-gradient(180deg, #f2fbf5 0%, #e3f6e8 100%);
        }

        .monitoring-metric-card.is-danger {
            background: linear-gradient(180deg, #fff3f4 0%, #fde5e8 100%);
        }

        .monitoring-metric-card.is-warning {
            background: linear-gradient(180deg, #fff9e7 0%, #fff1bf 100%);
        }

        .monitoring-metric-label {
            color: #6c757d;
            font-size: 0.9rem;
            margin-bottom: 0.35rem;
        }

        .monitoring-metric-value {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .monitoring-health-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
        }

        .monitoring-health-item {
            padding: 1rem;
            border-radius: 0.9rem;
            background: #f8f9fa;
            border: 1px solid rgba(15, 23, 42, 0.06);
        }

        .monitoring-health-title {
            color: #6c757d;
            font-size: 0.85rem;
            margin-bottom: 0.35rem;
        }

        .monitoring-health-value {
            font-size: 1.1rem;
            font-weight: 700;
        }
    </style>
}

<div class="content-card mb-3">
    <div class="monitoring-hero">
        <div>
            <h2 class="c-section-title mb-2">مراقبة النظام</h2>
            <p class="text-muted mb-0">لوحة متابعة مباشرة لصحة النظام ومؤشرات التكامل مع Alpeta.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span id="overallStatusBadge" class="monitoring-status-badge is-warning">جاري التحميل...</span>
            <button type="button" class="btn btn-outline btn-sm u-nowrap" onclick="loadMonitoringData()">Refresh</button>
        </div>
    </div>
</div>

<div class="content-card mb-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="c-section-title">System Health</h2>
        <span class="text-muted small">تحديث تلقائي كل 10 ثوانٍ</span>
    </div>
    <div class="monitoring-health-list">
        <div class="monitoring-health-item">
            <div class="monitoring-health-title">Status</div>
            <div id="healthStatus" class="monitoring-health-value">...</div>
        </div>
        <div class="monitoring-health-item">
            <div class="monitoring-health-title">Alpeta</div>
            <div id="healthAlpeta" class="monitoring-health-value">...</div>
        </div>
        <div class="monitoring-health-item">
            <div class="monitoring-health-title">Timestamp</div>
            <div id="healthTime" class="monitoring-health-value">...</div>
        </div>
    </div>
</div>

<div class="content-card mb-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="c-section-title">Metrics</h2>
        <div id="monitoringStatusText" class="fw-bold">Overall: ...</div>
    </div>
    <div class="monitoring-grid">
        <div class="monitoring-metric-card is-success">
            <div class="monitoring-metric-label">Assign Success</div>
            <div id="assignSuccess" class="monitoring-metric-value">0</div>
        </div>
        <div class="monitoring-metric-card is-danger">
            <div class="monitoring-metric-label">Assign Fail</div>
            <div id="assignFail" class="monitoring-metric-value">0</div>
        </div>
        <div class="monitoring-metric-card is-success">
            <div class="monitoring-metric-label">Unassign Success</div>
            <div id="unassignSuccess" class="monitoring-metric-value">0</div>
        </div>
        <div class="monitoring-metric-card is-danger">
            <div class="monitoring-metric-label">Unassign Fail</div>
            <div id="unassignFail" class="monitoring-metric-value">0</div>
        </div>
        <div class="monitoring-metric-card is-warning">
            <div class="monitoring-metric-label">Timeout Count</div>
            <div id="timeoutCount" class="monitoring-metric-value">0</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setText(id, value) {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
        }

        function updateOverallStatus(metrics) {
            const assignFail = Number(metrics.assignFail || 0);
            const timeoutCount = Number(metrics.timeoutCount || 0);

            let status = 'Healthy';
            let badgeClass = 'is-healthy';

            if (timeoutCount === 0 && assignFail === 0) {
                status = 'Healthy';
                badgeClass = 'is-healthy';
            } else if (timeoutCount < 5) {
                status = 'Warning';
                badgeClass = 'is-warning';
            } else {
                status = 'Degraded';
                badgeClass = 'is-degraded';
            }

            const badge = document.getElementById('overallStatusBadge');
            if (badge) {
                badge.textContent = status;
                badge.classList.remove('is-healthy', 'is-warning', 'is-degraded');
                badge.classList.add(badgeClass);
            }

            setText('monitoringStatusText', `Overall: ${status}`);
        }

        async function loadMonitoringData() {
            try {
                const [health, metrics] = await Promise.all([
                    fetch('/api/health', { cache: 'no-store' }).then(r => r.json()),
                    fetch('/api/metrics', { cache: 'no-store' }).then(r => r.json())
                ]);

                setText('healthStatus', health.status || 'unknown');
                setText('healthAlpeta', health.alpeta || 'unknown');
                setText('healthTime', health.time ? new Date(health.time).toLocaleString() : 'unknown');

                setText('assignSuccess', metrics.assignSuccess ?? 0);
                setText('assignFail', metrics.assignFail ?? 0);
                setText('unassignSuccess', metrics.unassignSuccess ?? 0);
                setText('unassignFail', metrics.unassignFail ?? 0);
                setText('timeoutCount', metrics.timeoutCount ?? 0);

                updateOverallStatus(metrics);
            } catch (error) {
                setText('healthStatus', 'fail');
                setText('healthAlpeta', 'unknown');
                setText('healthTime', new Date().toLocaleString());

                const badge = document.getElementById('overallStatusBadge');
                if (badge) {
                    badge.textContent = 'Degraded';
                    badge.classList.remove('is-healthy', 'is-warning');
                    badge.classList.add('is-degraded');
                }

                setText('monitoringStatusText', 'Overall: Degraded');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadMonitoringData();
            window.setInterval(loadMonitoringData, 10000);
        });
    </script>
}

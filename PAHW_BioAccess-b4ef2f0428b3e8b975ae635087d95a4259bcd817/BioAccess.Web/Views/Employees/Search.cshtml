@section Scripts {
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    function getEmployeeText() {
        const page = document.querySelector('.employees-search-page');
        const employeeId = (page?.dataset?.employeeId || '').trim();
        const employeeName = (page?.dataset?.employeeName || '').trim();
        if (employeeName && employeeId && employeeId !== '0') return `${employeeName} (${employeeId})`;
        if (employeeId && employeeId !== '0') return `Ø§Ù„Ù…ÙˆØ¸Ù Ø±Ù‚Ù… ${employeeId}`;
        return 'Ø§Ù„Ù…ÙˆØ¸Ù';
    }

    function getSelectedCards() {
        return Array.from(document.querySelectorAll('.device-chk:checked'))
            .map(cb => cb.closest('.device-card'))
            .filter(Boolean);
    }

    function getSelectedTerminalIds() {
        return getSelectedCards()
            .map(card => (card.dataset.terminalId || '').trim())
            .filter(Boolean);
    }

    function getSelectedStateKeys() {
        return getSelectedCards()
            .map(c => (c.dataset.stateKey || '').trim())
            .filter(Boolean);
    }

    function getUnique(items) {
        return Array.from(new Set(items.filter(Boolean)));
    }

    function clearSelection() {
        document.querySelectorAll('.device-chk:checked').forEach(cb => {
            cb.checked = false;
            const card = cb.closest('.device-card');
            if (card) card.classList.remove('selected');
        });
        updateBulkBar();
    }

    function updateBulkBar() {
        const selectedCount = document.querySelectorAll('.device-chk:checked').length;
        document.getElementById('selectedCount').textContent = String(selectedCount);
        document.getElementById('selectedLabel').textContent = `ØªÙ… ØªØ­Ø¯ÙŠØ¯ ${selectedCount} Ø¬Ù‡Ø§Ø²`;

        const bar = document.getElementById('bulkBar');
        bar.classList.toggle('show', selectedCount > 0);
        bar.classList.toggle('is-single', selectedCount === 1);

        updateBulkControls();
    }

    function updateDeviceSelection(checkbox) {
        const card = checkbox.closest('.device-card');
        if (checkbox.checked) {
            card.classList.add('selected');
        } else {
            card.classList.remove('selected');
        }
        updateBulkBar();
    }

    function toggleDeviceCheckbox(checkboxId) {
        const checkbox = document.getElementById(checkboxId);
        checkbox.checked = !checkbox.checked;
        updateDeviceSelection(checkbox);
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateBulkBar();
        onBulkOperationChange();

        flatpickr('.datepicker', {
            dateFormat: 'd/m/Y',
            altInput: true,
            altFormat: 'd/m/Y',
            allowInput: true,
            clickOpens: true,
            disableMobile: true
        });

        document.getElementById('bulkStartDate')?.addEventListener('change', updateBulkControls);
        document.getElementById('bulkEndDate')?.addEventListener('change', updateBulkControls);
    });

    function convertDateFormat(dateStr) {
        if (!dateStr) return '';
        const parts = dateStr.split('/');
        if (parts.length === 3) return `${parts[2]}-${parts[1]}-${parts[0]}`;
        return dateStr;
    }

    function toggleRegionCollapse(collapseId) {
        const element = document.getElementById(collapseId);
        const header = element.previousElementSibling;

        if (element.classList.contains('show')) {
            element.classList.remove('show');
            header.classList.remove('active');
        } else {
            element.classList.add('show');
            header.classList.add('active');
        }
    }

    function onBulkOperationChange() {
        const op = (document.getElementById('bulkOperation')?.value || '').trim();
        const dates = document.getElementById('bulkDates');
        const showDates = op === 'delegate';
        dates.classList.toggle('is-hidden', !showDates);
        dates.setAttribute('aria-hidden', String(!showDates));
        updateBulkControls();
    }

    function updateBulkControls() {
        const op = (document.getElementById('bulkOperation')?.value || '').trim();
        const btn = document.getElementById('bulkExecuteBtn');
        const count = getSelectedTerminalIds().length;

        let canRun = count > 0;
        const stateKeys = getSelectedStateKeys();
        const uniqueStates = getUnique(stateKeys);

        if (canRun && uniqueStates.length > 1) canRun = false;

        if (op === 'delegate') {
            const sd = (document.getElementById('bulkStartDate')?.value || '').trim();
            const ed = (document.getElementById('bulkEndDate')?.value || '').trim();
            canRun = canRun && !!sd && !!ed;
        }

        if (canRun && uniqueStates.length === 1) {
